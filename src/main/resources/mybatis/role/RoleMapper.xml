<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.noonoo.prjtbackend.role.mapper.RoleMapper">

    <select id="findAllActiveRoles" resultType="com.noonoo.prjtbackend.role.dto.RoleDto">
        SELECT
            ROLE_ID   AS roleId
             , ROLE_NAME AS roleName
             , ROLE_CODE AS roleCode
             , USE_YN    AS useYn
        FROM ROLE
        WHERE USE_YN = 'Y'
        ORDER BY ROLE_ID ASC
    </select>

</mapper>